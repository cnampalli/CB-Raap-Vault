# Copy to .env and fill in real values. NEVER commit .env.
# Per CLAUDE.md, all API keys / credentials live here and nowhere else.

# --- HashiCorp Vault ---
VAULT_ADDR=https://<vault-vip>:8200
VAULT_NAMESPACE=AUT
# VAULT_TOKEN=            # short-lived; prefer OIDC/cert auth over a static token

# --- CloudBees CI ---
# CLOUDBEES_CI_URL=
# CLOUDBEES_CI_TOKEN=

# --- Add other service credentials below ---
