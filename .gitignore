# Secrets — never commit these (see CLAUDE.md: credentials live only in .env)
.env
credentials.json
token.json

# Key material — ZeroTrust signing keys are generated offline, never committed (guide 03a)
*.pem
*.key
zerotrust-*.pem

# Disposable processing files — regenerated as needed
.tmp/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
